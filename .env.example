# ============================================================
# .env 설정 파일 (복사 후 .env로 이름 변경)
# ============================================================
# cp .env.example .env

# ── Supabase (모든 사이트 공용) ──
# 단일 Supabase 프로젝트를 84개 사이트가 공유합니다.
# 아래 값을 그대로 복사하여 .env에 넣으세요.
VITE_SUPABASE_URL=https://hcmgdztsgjvzcyxyayaj.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── PortOne 결제 (카드/계좌이체) ──
# 모든 사이트에서 동일한 가맹점 사용
VITE_IMP_CODE=imp61949262
VITE_PG_PROVIDER=html5_inicis.MOIkorcom1

# ── Site URL (배포 도메인) ──
# site.ts의 url과 일치해야 합니다
VITE_SITE_URL=https://new-site.dreamitbiz.com
